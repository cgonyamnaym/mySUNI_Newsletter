# Gemini API 키 — https://aistudio.google.com/app/apikey 에서 무료 발급
# 이 파일을 복사해서 .env.local 로 저장 후 키를 입력하세요
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail SMTP — 발송 전용 Gmail 계정 (구글 계정 설정 > 보안 > 2단계 인증 활성화 후 "앱 비밀번호" 발급)
# /generate, /n/[id] 페이지의 "무료 구독 신청" 폼이 서버(/api/subscribe)에서 haileycho@sk.com으로 이메일을 전달하는 데 사용
# (일반 로그인 비밀번호가 아닌 앱 비밀번호를 사용해야 함 — https://myaccount.google.com/apppasswords)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
