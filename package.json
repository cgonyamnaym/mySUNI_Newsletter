{
  "name": "energy-insight-newsletter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "collect": "node scripts/collect.js",
    "biweekly": "node scripts/biweekly-report.js",
    "biweekly:force": "node scripts/biweekly-report.js --force",
    "biweekly:dry": "node scripts/biweekly-report.js --force --dry-run",
    "build-search-index": "node scripts/build-search-index.js",
    "crawl": "node scripts/run-crawl.js && node scripts/build-search-index.js",
    "crawl:dry": "node scripts/run-crawl.js --dry-run --no-sum",
    "crawl:3days": "node scripts/run-crawl.js --days=3 && node scripts/build-search-index.js",
    "summarize:top": "node scripts/summarize-top-articles.js",
    "summarize:top:dry": "node scripts/summarize-top-articles.js --dry-run",
    "newsletter:prep": "node scripts/run-crawl.js && node scripts/summarize-top-articles.js",
    "scheduler:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-scheduler.ps1",
    "scheduler:run": "powershell -Command \"Start-ScheduledTask -TaskName 'EnergyInsight-DailyCrawl'\"",
    "scheduler:status": "powershell -Command \"Get-ScheduledTask -TaskName 'EnergyInsight-DailyCrawl' | Select-Object TaskName,State\"",
    "log": "powershell -Command \"Get-Content logs/crawl.log -Tail 50\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop newsletter-dashboard",
    "pm2:restart": "pm2 restart newsletter-dashboard",
    "pm2:logs": "pm2 logs newsletter-dashboard",
    "pm2:status": "pm2 status",
    "firewall:allow": "powershell -Command \"New-NetFirewallRule -DisplayName 'Newsletter Dashboard' -Direction Inbound -Protocol TCP -LocalPort 3000 -Action Allow\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/bcryptjs": "^2.4.6",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.0.0",
    "lucide-react": "^1.14.0",
    "next": "^14.2.5",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
